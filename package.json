{
  "name": "gm-orchestrator",
  "version": "0.10.0",
  "description": "Tokenless Claude Code orchestrator for GraphMemory — AI-first, TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli/index.js"
  },
  "bin": {
    "gm-orchestrator": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsx scripts/build.ts",
    "build:ts": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build:ui": "cd ui && npm install && npm run build",
    "dev:ui": "cd ui && npm run dev",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "graphmemory",
    "orchestrator",
    "ai",
    "task-runner"
  ],
  "author": "vachick <googdeev@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2dmaster/gm-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/2dmaster/gm-orchestrator/issues"
  },
  "homepage": "https://github.com/2dmaster/gm-orchestrator#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/node-notifier": "^8.0.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "express": "^5.2.1",
    "node-notifier": "^10.0.1",
    "open": "^11.0.0",
    "ws": "^8.20.0"
  }
}
